NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
# DATABASE_URL=file:./study.db

# AI features — get a key at https://platform.openai.com/api-keys
# Model is set in lib/ai.ts (default: gpt-5.4)
OPENAI_API_KEY=sk-your-key-here

# Per-user lifetime AI token cap. Used as the fallback when users.ai_token_limit
# is null. Admins can override per-user from the Users tab. Set to 0 to disable
# the cap entirely (unlimited). Defaults to 500000 when unset.
# AI_TOKEN_LIMIT_DEFAULT=500000

# Vercel Blob — required for user PDF uploads/drive (set automatically on Vercel, manual setup for local dev)
# Get a token at: vercel.com → your project → Storage → Blob → Create store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# Archive.org S3 API keys — required for the dev panel "Upload to Archive" feature
# Get your keys at https://archive.org/account/s3.php
ARCHIVE_ACCESS_KEY=your-access-key-here
ARCHIVE_SECRET_KEY=your-secret-key-here
