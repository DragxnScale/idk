NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
# DATABASE_URL=file:./study.db

# AI features — get a key at https://platform.openai.com/api-keys
# Model is set in lib/ai.ts (default: gpt-5.4)
OPENAI_API_KEY=sk-your-key-here

# Per-user lifetime AI token cap. Used as the fallback when users.ai_token_limit
# is null. Admins can override per-user from the Users tab. Defaults to 0
# (unlimited — usage is still tracked for admins, just not enforced). Set this
# to any positive number to apply a blanket cap across every user.
# AI_TOKEN_LIMIT_DEFAULT=0

# ── PDF storage backend ──────────────────────────────────────────────
# Cloudflare R2 is the active backend. The Vercel Blob fallback path is
# kept only to read leftover legacy URLs during the cutover window; once
# `scripts/migrate-vercel-blob-to-r2.mjs` reports zero remaining VB URLs
# in the DB the VB SDK is removed entirely. See lib/storage-backend.ts.
STORAGE_BACKEND=r2

# Vercel Blob — required ONLY during migration so legacy VB URLs are
# still readable. Drop this var after the rip-out step.
# Get a token at: vercel.com → your project → Storage → Blob → Create store
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# Cloudflare R2 (S3-compatible). Create a bucket + S3 API token in the
# Cloudflare dashboard (R2 Object Storage → Manage R2 API Tokens, scope:
# Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bowl-beacon-pdfs
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Public R2 base URL. Required for the byte-bypass: /api/blob/serve
# 302-redirects public-key reads here so the bytes flow R2 edge →
# browser, not browser → Vercel → R2 → browser. Use the bucket's free
# r2.dev subdomain (Cloudflare R2 → bucket → Settings → enable r2.dev)
# or, for production scale, attach a custom domain.
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
# Same value, exposed to the browser so pdfClientLoadUrl() can detect
# already-direct R2 URLs and skip the /api/blob/serve hop.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# Archive.org S3 API keys — required for the dev panel "Upload to Archive" feature
# Get your keys at https://archive.org/account/s3.php
ARCHIVE_ACCESS_KEY=your-access-key-here
ARCHIVE_SECRET_KEY=your-secret-key-here

# YouTube Data API v3 — used by /api/ai/videos to resolve AI-generated topics
# into real video URLs scoped to specific educators (Organic Chem Tutor,
# Amoeba Sisters, etc.). Free tier: 10k units/day; each search costs 100.
# Without this key the feature still works but degrades to a YouTube search URL.
# Setup: https://console.cloud.google.com/ → Library → enable "YouTube Data API v3"
# → Credentials → Create credentials → API key → restrict to "YouTube Data API v3".
# YOUTUBE_API_KEY=
