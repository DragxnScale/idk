NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
# DATABASE_URL=file:./study.db

# AI features — get a key at https://platform.openai.com/api-keys
# Model is set in lib/ai.ts (default: gpt-5.4)
OPENAI_API_KEY=sk-your-key-here

# Per-user lifetime AI token cap. Used as the fallback when users.ai_token_limit
# is null. Admins can override per-user from the Users tab. Defaults to 0
# (unlimited — usage is still tracked for admins, just not enforced). Set this
# to any positive number to apply a blanket cap across every user.
# AI_TOKEN_LIMIT_DEFAULT=0

# ── PDF storage backend ──────────────────────────────────────────────
# "vercel-blob" (default) or "r2" (Cloudflare R2). Switching to "r2"
# requires the R2_* vars below + a copy migration. See lib/storage-backend.ts.
# STORAGE_BACKEND=vercel-blob

# Vercel Blob — required while STORAGE_BACKEND is "vercel-blob".
# Also required during migration so old VB URLs are still readable.
# Get a token at: vercel.com → your project → Storage → Blob → Create store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# Cloudflare R2 — required when STORAGE_BACKEND=r2 (or while running the
# migration script). Create a bucket + S3 API token in the Cloudflare
# dashboard (R2 Object Storage → Manage R2 API Tokens, scope: Object Read & Write).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=bowl-beacon-pdfs
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Optional: only set if you've connected a custom public domain to the
# bucket. The app does not need this; reads always go through /api/blob/serve.
# R2_PUBLIC_BASE_URL=https://pdfs.example.com

# Archive.org S3 API keys — required for the dev panel "Upload to Archive" feature
# Get your keys at https://archive.org/account/s3.php
ARCHIVE_ACCESS_KEY=your-access-key-here
ARCHIVE_SECRET_KEY=your-secret-key-here
